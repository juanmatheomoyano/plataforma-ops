{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capacidades por defecto — acceso a ventana y HTTP al backend remoto",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "opener:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://plataforma-ops-production.up.railway.app/**" },
        { "url": "http://192.168.1.96:8000/**" }
      ]
    }
  ]
}
