{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plataforma Operativa",
  "version": "1.0.0",
  "identifier": "com.provincianet.plataforma-ops",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Plataforma Operativa — Provincia Compras",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://plataforma-ops-production.up.railway.app/api/updates/latest"],
      "dangerousInsecureTransportProtocol": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
