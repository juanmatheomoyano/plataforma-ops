{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Provincia Ops",
  "version": "1.7.2",
  "identifier": "com.provincianet.plataforma-ops",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Provincia Ops",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://plataforma-ops-production.up.railway.app; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://plataforma-ops-production.up.railway.app/api/updates/latest"],
      "dangerousInsecureTransportProtocol": false,
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Provincia NET",
    "category": "Business",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
