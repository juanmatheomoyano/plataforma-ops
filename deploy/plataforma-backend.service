[Unit]
Description=Plataforma Operativa - Backend FastAPI
After=network.target postgresql.service

[Service]
User=juan
WorkingDirectory=/home/juan/plataforma-ops/backend
Environment="PATH=/home/juan/plataforma-ops/venv/bin"
EnvironmentFile=/home/juan/plataforma-ops/backend/.env
ExecStart=/home/juan/plataforma-ops/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
